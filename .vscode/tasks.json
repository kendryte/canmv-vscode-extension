{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: compile",
      "type": "npm",
      "script": "compile",
      "path": "extension",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "canmv: stage current backend",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/scripts/stage-current-backend.sh"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "canmv: debug build",
      "dependsOrder": "sequence",
      "dependsOn": [
        "npm: compile",
        "canmv: stage current backend"
      ],
      "problemMatcher": []
    }
  ]
}
